
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume Template</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Arial', sans-serif;
            line-height: 1.4;
            color: #333;
            padding: 40px;
            background-color: white;
            -webkit-print-color-adjust: exact;
        }

        .header {
            text-align: center;
            margin-bottom: 15px;
        }

        .header h1 {
            font-size: 24px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .contact-info {
            font-size: 11px;
            color: #555;
        }

        .section {
            margin-top: 15px;
        }

        .section-title {
            font-size: 17px;
            font-weight: bolder;
            color: rgb(143, 139, 139);
            margin-bottom: 8px;
            padding-bottom: 2px;
            text-transform: uppercase;
            border-bottom: 1px solid #eee;
        }

        .profile-text {
            font-size: 11px;
        }

        .entry {
            margin-bottom: 10px;
        }

        .entry-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            font-weight: bold;
            font-size: 12px;
        }

        .entry-sub-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            font-style: italic;
            font-size: 11px;
            margin-bottom: 3px;
        }

        .location-date {
            font-weight: normal;
            font-size: 11px;
        }

        ul {
            margin-left: 18px;
            font-size: 11px;
        }

        li {
            margin-bottom: 2px;
        }

        .skills-container, .achievements-container {
            font-size: 11px;
        }

        .skills-label {
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1><%= personalInfo.fullName %></h1>
        <div class="contact-info">
            <%= personalInfo.contactBar %>
        </div>
    </div>

    <% if (profile) { %>
    <div class="section">
        <div class="section-title">Profile</div>
        <p class="profile-text"><%= profile %></p>
    </div>
    <% } %>

    <% if (education && education.length > 0) { %>
    <div class="section">
        <div class="section-title">Education</div>
        <% education.forEach(function(edu) { %>
        <div class="entry">
            <div class="entry-header">
                <span><%= edu.institution %></span>
                <% if (edu.dateRange) { %><span class="location-date"><%= edu.dateRange %></span><% } %>
            </div>
            <div class="entry-sub-header">
                <span><%= edu.degree %></span>
                <% if (edu.location) { %><span class="location-date"><%= edu.location %></span><% } %>
            </div>
            <% if (edu.details && edu.details.length > 0) { %>
            <ul>
                <% edu.details.forEach(function(detail) { %>
                <li><%= detail %></li>
                <% }) %>
            </ul>
            <% } %>
        </div>
        <% }); %>
    </div>
    <% } %>

    <div class="section">
        <div class="section-title">Skills</div>
        <div class="skills-container">
            <% if (skills.technical && skills.technical.length > 0) { %>
            <div><span class="skills-label">Technical:</span> <%= skills.technical.join(', ') %></div>
            <% } %>
            <% if (skills.tools && skills.tools.length > 0) { %>
            <div><span class="skills-label">Tools:</span> <%= skills.tools.join(', ') %></div>
            <% } %>
        </div>
    </div>

    <% if (certifications && certifications.length > 0) { %>
    <div class="section">
        <div class="section-title">Certifications</div>
        <div class="achievements-container">
            <ul>
                <% certifications.forEach(function(cert) { %>
                <li><%= cert %></li>
                <% }); %>
            </ul>
        </div>
    </div>
    <% } %>

    <% if (experience && experience.length > 0) { %>
    <div class="section">
        <div class="section-title">Experience</div>
        <% experience.forEach(function(exp) { %>
        <div class="entry">
            <div class="entry-header">
                <span><%= exp.company %></span>
                <% if (exp.dateRange) { %><span class="location-date"><%= exp.dateRange %></span><% } %>
            </div>
            <div class="entry-sub-header">
                <span><%= exp.role %></span>
                <% if (exp.location) { %><span class="location-date"><%= exp.location %></span><% } %>
            </div>
            <ul>
                <% exp.bulletPoints.forEach(function(point) { %>
                <li><%= point %></li>
                <% }); %>
            </ul>
        </div>
        <% }); %>
    </div>
    <% } %>

    <% if (projects && projects.length > 0) { %>
    <div class="section">
        <div class="section-title">Projects</div>
        <% projects.forEach(function(proj) { %>
        <div class="entry">
            <div class="entry-header">
                <span><%= proj.title %></span>
                <% if (proj.dateRange) { %><span class="location-date"><%= proj.dateRange %></span><% } %>
            </div>
            <ul>
                <% proj.details.forEach(function(detail) { %>
                <li><%= detail %></li>
                <% }); %>
            </ul>
        </div>
        <% }); %>
    </div>
    <% } %>

    <% if (achievements && achievements.length > 0) { %>
    <div class="section">
        <div class="section-title">Achievements</div>
        <div class="achievements-container">
            <ul>
                <% achievements.forEach(function(ach) { %>
                <li><%= ach %></li>
                <% }); %>
            </ul>
        </div>
    </div>
    <% } %>

</body>
</html>